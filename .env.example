# Google Workspace MCP — OAuth credentials
# See https://github.com/taylorwilsdon/google_workspace_mcp for setup instructions.
# Copy this file to .env and fill in your values.

export GOOGLE_OAUTH_CLIENT_ID="your-client-id.apps.googleusercontent.com"
export GOOGLE_OAUTH_CLIENT_SECRET="GOCSPX-your-secret"
export USER_GOOGLE_EMAIL="you@example.com"
